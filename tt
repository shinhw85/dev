public static Map<String, Object> parseWithUpperKeys(String jsonString, ObjectMapper objectMapper) throws JsonProcessingException {
        Map<String, Object> map = objectMapper.readValue(jsonString, new TypeReference<Map<String, Object>>() {});
        return (Map<String, Object>) convert(map);
    }

    private static Object convert(Object obj) {
        if (obj instanceof Map) {
            Map<String, Object> original = (Map<String, Object>) obj;
            Map<String, Object> result = new LinkedHashMap<>();
            for (Map.Entry<String, Object> entry : original.entrySet()) {
                result.put(entry.getKey().toUpperCase(), convert(entry.getValue()));
            }
            return result;
        } else if (obj instanceof List) {
            List<Object> original = (List<Object>) obj;
            List<Object> result = new ArrayList<>(original.size());
            for (Object item : original) {
                result.add(convert(item));
            }
            return result;
        } else {
            // String, Number, Boolean, null 등 리프 값은 그대로 반환
            return obj;
        }
    }